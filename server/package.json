{
  "name": "plan-manager-server",
  "version": "1.0.0",
  "description": "Plan Manager Backend API",
  "main": "dist/interface/index.js",
  "scripts": {
    "dev": "tsx watch src/interface/index.ts",
    "build": "tsc",
    "start": "node dist/interface/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "zod": "^3.11.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.3",
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.5.2",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
